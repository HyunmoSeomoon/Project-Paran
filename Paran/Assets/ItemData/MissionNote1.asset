  itemIcon: {fileID: 21300000, guid: 341d7b06d265b23498dd072c49653dfa, type: 3}
  itemDescription: "\uB188\uB4E4\uC758 \uC218\uB9AC \uAE30\uC0AC\uB85C \uC704\uC7A5\uD574
    \uB4DC\uB514\uC5B4 \uC774\uACF3\uC5D0 \uB4E4\uC5B4\uC624\uB294 \uB370 \uC131\uACF5\uD560
    \uC218 \uC788\uC5C8\uB2E4. \uC774 \uC77C\uC9C0\uB294 \uB9CC\uC57D \uC77C\uC774
    \uC798\uBABB\uB410\uC744 \uACBD\uC6B0, \uB204\uAD70\uAC00\uAC00 \uB0B4 \uC758\uC9C0\uB97C
    \uC774\uC5B4\uBC1B\uC744 \uC218 \uC788\uB3C4\uB85D \uC791\uC131\uD574 \uC774\uACF3
    \uC800\uACF3\uC5D0 \uC228\uACA8\uB193\uC558\uB2E4. \uC774\uAC78 \uBCF4\uB294
    \uB2F9\uC2E0\uC740, \uAF2D \uC131\uACF5\uD560 \uC218 \uC788\uAE30\uB97C \uBC14\uB780\uB2E4."
