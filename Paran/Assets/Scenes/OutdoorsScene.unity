--- !u!1001 &1006007403561211496
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 438805999}
    m_Modifications:
    - target: {fileID: 532666975618710192, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: m_Name
      value: I_npc1
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: Camera
      value: 
      objectReference: {fileID: 1823688467}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: player
      value: 
      objectReference: {fileID: 1698001920}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: uIManager
      value: 
      objectReference: {fileID: 2087315336}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.size
      value: 12
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[9].dialogueEnd
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[0].dialogueText
      value: "\uC21C\uACBD: \uC5B4\uC774 \uC790\uB124! \uB0B4\uAC00 \uAE30\uB2E4\uB9AC\uACE0
        \uC788\uC5C8\uB124."
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[10].dialogueEnd
      value: 0
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[11].dialogueEnd
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[1].dialogueText
      value: "\uC1A1\uD601: \uBB34\uC2A8 \uC77C\uC774\uC2DC\uC8E0?"
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[2].dialogueText
      value: "\uC21C\uACBD: \uC790\uB124\uAC00 \uBB34\uC2A8\uC77C\uC744 \uD558\uB7EC\uC654\uB294\uC9C0,
        \uB204\uAD6C\uC778\uC9C0 \uB098\uB294 \uC54C\uACE0 \uC788\uB2E4\uB124."
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[3].dialogueText
      value: "\uC1A1\uD601: \uD558\uD558... \uC9C0\uAE08 \uBB34\uC2A8 \uB9D0\uC744
        \uD558\uC2DC\uB294 \uAC74\uC9C0.."
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[4].dialogueText
      value: "\uC21C\uACBD: \uC591\uC0DD\uC900 \uC120\uC0DD\uB2D8\uAED8 \uC774\uC57C\uAE30
        \uB9CE\uC774 \uB4E4\uC5C8\uB124. \uB098\uB294 \uBBFF\uC5B4\uB3C4 \uB418\uB294
        \uC0AC\uB78C\uC774\uC57C. \uC790\uB124\uC5D0\uAC8C \uBD80\uD0C1\uD560 \uC77C\uC774
        \uC788\uC5B4 \uC774\uB807\uAC8C \uB9D0\uC744 \uAC78\uC5C8\uB124."
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[5].dialogueText
      value: "\uC1A1\uD601: \uBB34\uC2A8 \uC77C\uC774\uC2DC\uC8E0?"
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[6].dialogueText
      value: "\uC21C\uACBD: \uB0B4\uAC00 \uC790\uB124\uB4E4\uC744 \uB3C4\uC6B4 \uC0AC\uC2E4\uC744
        \uB3D9\uB8CC \uD55C\uBA85\uC5D0\uAC8C \uB4E4\uD0A8\uAC70 \uAC19\uC544...
        \uC790\uB124\uAC00 \uB140\uC11D\uC744 \uCC98\uB9AC\uD574 \uC92C\uC73C\uBA74
        \uD558\uB294\uB370"
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[7].dialogueText
      value: 
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[8].dialogueText
      value: "\uC21C\uACBD: \uB0B4\uAC00 \uC790\uB124\uB4E4\uC744 \uB3D5\uB290\uB77C
        \uC774\uB9AC \uB41C\uAC70\uC9C0 \uC54A\uB098. \uC790\uB124\uC758 \uC815\uCCB4\uB97C
        \uB0B4\uAC00 \uC54C\uACE0 \uC788\uB2E4\uB294 \uC0AC\uC2E4\uC744 \uC78A\uC9C0
        \uB9D0\uAC8C\uB098"
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[9].dialogueText
      value: "\uC21C\uACBD: \uC790\uB124\uAC00 \uC77C\uC744 \uC5B4\uB5BB\uAC8C \uCC98\uB9AC\uD560\uC9C0
        \uC798 \uC9C0\uCF1C\uBCF4\uACE0 \uC788\uACA0\uB124. \uB140\uC11D\uC740 \uC67C\uCABD
        \uB05D \uBCF5\uB3C4 \uC544\uB798\uCABD \uC0AC\uBB34\uC2E4\uC5D0 \uC788\uB124."
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[10].dialogueText
      value: "\uC21C\uACBD"
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[11].dialogueText
      value: "\uC21C\uACBD: \uADF8\uB7FC \uC790\uB124\uC5D0\uAC8C \uB9CF\uAE30\uB3C4\uB85D
        \uD558\uC9C0. \uB140\uC11D\uC740 \uC67C\uCABD \uB05D \uBCF5\uB3C4 \uC544\uB798\uCABD
        \uC0AC\uBB34\uC2E4\uC5D0 \uC788\uB124."
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[7].choices.Array.size
      value: 3
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[8].choices.Array.size
      value: 0
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[7].choices.Array.data[0].choiceText
      value: "\uC81C\uAC00 \uC65C \uADF8\uB798\uC57C \uD558\uC8E0?"
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[7].choices.Array.data[1].choiceText
      value: "\uB9E1\uACA8\uB9CC \uC8FC\uC2DC\uC8E0."
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[7].choices.Array.data[2].choiceText
      value: "\uC2EB\uC740\uB370\uC694."
      objectReference: {fileID: 0}
