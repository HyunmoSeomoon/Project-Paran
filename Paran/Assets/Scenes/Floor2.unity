MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2054722542}
  m_Enabled: 0
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f0e160b87b6b6e24fbb280271a409c27, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  player: {fileID: 1698001920}
  dialogues:
  - dialogueText: "\uC1A1\uD601: \uC774\uC81C \uC548\uC2EC\uD574\uB3C4 \uB3FC."
    choices: []
    dialogueEnd: 0
    OnDialogueNodeEnd:
      m_PersistentCalls:
        m_Calls: []
  - dialogueText: "\uC21C\uACBD: \uCC38 \uACE0\uB9D9\uAE30\uB098 \uD558\uAD70. \uADF8\uCABD\uC5D0\uC11C
      \uC815\uBCF4\uAD00\uB9AC\uB97C \uC5B4\uB5BB\uAC8C \uD558\uB294\uAC70\uC57C?"
    choices: []
    dialogueEnd: 0
    OnDialogueNodeEnd:
      m_PersistentCalls:
        m_Calls: []
  - dialogueText: 
    choices:
    - choiceText: "\uC54C\uAC8C \uBB50\uC57C. \uB108\uAC00 \uC2DC\uD0A8 \uC77C\uC740
        \uB2E4 \uD588\uC73C\uB2C8 \uB0B4\uAC00 \uBB3C\uC5B4\uBCF4\uB294 \uB9D0\uC5D0
        \uB300\uB2F5\uC774\uB098 \uD574."
      nextDialogueIndex: 3
      OnDialogueNodeEnd:
        m_PersistentCalls:
          m_Calls: []
    - choiceText: "\uC815\uB9D0 \uBBF8\uC548\uD574. \uBB50 \uD558\uB098 \uBB3C\uC5B4\uBCFC\uAC8C
        \uC788\uC5B4."
      nextDialogueIndex: 5
      OnDialogueNodeEnd:
        m_PersistentCalls:
          m_Calls: []
    dialogueEnd: 0
    OnDialogueNodeEnd:
      m_PersistentCalls:
        m_Calls: []
  - dialogueText: "\uC21C\uACBD: \uC774\uB530\uAD6C\uB85C \uB0A0 \uCDE8\uAE09\uD558\uBA74
      \uB108\uC5D0 \uB300\uD574 \uB2E4 \uAE4C\uBC1C\uB9AC\uB294 \uC218\uBC16\uC5D0
      \uC5C6\uB2E4\uB2C8\uAE4C?"
    choices: []
    dialogueEnd: 0
    OnDialogueNodeEnd:
      m_PersistentCalls:
        m_Calls: []
  - dialogueText: "\uC1A1\uD601: \uB098\uB3C4 \uC9C0\uAE08 \uB2F9\uC7A5 \uC554\uC0B4\uC744
      \uD3EC\uAE30\uD558\uACE0 \uB108\uC758 \uC815\uCCB4\uB97C \uC54C\uB9AC\uB294
      \uC218\uB3C4 \uC788\uC9C0. \uC11C\uB85C \uAC19\uC740 \uCC98\uC9C0\uB2C8 \uC880
      \uB3C4\uC640\uB2EC\uB77C\uACE0."
    choices: []
    dialogueEnd: 0
    OnDialogueNodeEnd:
      m_PersistentCalls:
        m_Calls: []
  - dialogueText: "\uC21C\uACBD: \uC9C8\uBB38\uD558\uB824\uB294\uAC8C \uBB54\uB370?"
    choices: []
    dialogueEnd: 0
    OnDialogueNodeEnd:
      m_PersistentCalls:
        m_Calls: []
  - dialogueText: "\uC1A1\uD601: \uB108 \uB9D0\uACE0\uB3C4 \uD55C\uBA85\uC774 \uB354
      \uC774\uACF3\uC5D0 \uC788\uC5C8\uC5B4. \uD558\uC9C0\uB9CC \uC5B4\uCC0C\uB41C
      \uC77C\uC778\uC9C0 \uC804\uD600 \uC5F0\uB77D\uC774 \uB2FF\uC9C0 \uC54A\uC558\uC9C0.
      \uADF8 \uC0AC\uB78C\uC5D0 \uB300\uD574 \uB4E3\uAC70\uB098 \uC544\uB294\uBC14\uAC00
      \uC788\uC744\uAE4C?"
    choices: []
    dialogueEnd: 0
    OnDialogueNodeEnd:
      m_PersistentCalls:
        m_Calls: []
  - dialogueText: "\uC21C\uACBD: \uB204\uAD70\uC9C0\uB294 \uBAA8\uB974\uACA0\uC9C0\uB9CC...
      \uC5BC\uB9C8\uC804\uC5D0 \uACBD\uBB34\uAD6D\uC7A5 \uB618\uB9C8\uB2C8\uAC00
      \uD53C\uBB3B\uC740 \uC637\uC744 \uD0DC\uC6B0\uACE0 \uC18C\uC9C0\uD488\uC740
      \uCC3D\uACE0\uC5D0 \uB123\uC5B4\uB1A8\uC5B4. \uCC3D\uACE0\uB85C \uD55C\uBC88
      \uAC00\uBCF4\uB294\uAC8C \uC5B4\uB54C?"
    choices: []
    dialogueEnd: 0
    OnDialogueNodeEnd:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 2087315338}
          m_TargetAssemblyTypeName: MissionManager, Assembly-CSharp
          m_MethodName: CompleteMission
          m_Mode: 5
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: talk with cop 2
            m_BoolArgument: 0
          m_CallState: 2
  - dialogueText: "\uC1A1\uD601: \uACE0\uB9C8\uC6CC."
    choices: []
    dialogueEnd: 0
