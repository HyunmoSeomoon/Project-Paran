  itemDescription: "\uC870\uC120\uCD1D\uB3C5 \uAC01\uD558.\r\n\uC870\uC120\uC758
    \uBC94\uC8C4 \uC870\uC9C1 \uB188\uB4E4\uC774 \uB2F9\uC2E0\uC758 \uC554\uC0B4\uC744
    \uACC4\uD68D\uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4. \uC624\uB298\uC758 \uC0DD\uC77C
    \uC5F0\uD68C\uC5D0 \uC7A0\uC785\uD558\uC5EC \uACF5\uACA9\uD558\uB824 \uD55C\uB2E4\uB294
    \uBCF4\uACE0\uAC00 \uC788\uC2B5\uB2C8\uB2E4. \uBAB8\uC744 \uD53C\uD558\uACE0,
    \uADF8 \uC218\uAD34\uB4E4\uC744 \uCCB4\uD3EC\uD558\uAE30 \uBC14\uB78D\uB2C8\uB2E4.\r\n\u2015
    \uC774\uCF00\uB2C8\uC5D0"
