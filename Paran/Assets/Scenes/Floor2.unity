--- !u!1001 &1006007403561211496
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 438805999}
    m_Modifications:
    - target: {fileID: 532666975618710192, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: m_Name
      value: I_npc1
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: Camera
      value: 
      objectReference: {fileID: 1823688467}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: player
      value: 
      objectReference: {fileID: 1698001920}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: uIManager
      value: 
      objectReference: {fileID: 2087315336}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: missionName
      value: 
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.size
      value: 12
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[9].dialogueEnd
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[0].dialogueText
      value: "\uC21C\uACBD: \uB108\uB0D0? \uC774\uB534 \uB9D0\uB3C4 \uC548 \uB418\uB294
        \uACC4\uD68D\uC744 \uC138\uC6B4\uAC8C?"
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[10].dialogueEnd
      value: 0
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[11].dialogueEnd
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[1].dialogueText
      value: "\uC1A1\uD601: \uBB34\uC2A8..?"
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[2].dialogueText
      value: "\uC21C\uACBD: \uB2E5\uCCD0, \uB2E4 \uC54C\uACE0 \uC788\uC73C\uB2C8\uAE4C.
        \uC77C\uCC98\uB9AC\uB97C \uC774\uB530\uC704\uB85C \uD574? \uBA87 \uD47C \uC900\uB2E4\uACE0
        \uB208 \uB3CC\uC544\uAC00\uC11C \uC81C\uAD6D\uC744 \uD314\uC544\uB118\uAE34
        \uB0B4 \uC798\uBABB\uC774\uC9C0...\r\n\uC774\uAC8C \uBB34\uC2A8 \uB73B\uC778\uC9C0
        \uC54C\uAE30\uB098 \uD574?"
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[3].dialogueText
      value: "\uC1A1\uD601: \uC9C4\uC815\uD574."
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[4].dialogueText
      value: "\uC21C\uACBD: \uD558... \uB124\uB188\uB4E4, \uC774 \uAC74\uBB3C\uC758
        \uC9C0\uB3C4\uB97C \uAC00\uC9C0\uACE0 \uC788\uC9C0? \uADF8\uAC70 \uB0B4\uAC00
        \uC900 \uAC70\uC57C. \uC528\uBC1C... \uADF8\uB7EC\uC9C0 \uB9D0\uC558\uC5B4\uC57C
        \uD588\uB294\uB370...\r"
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[5].dialogueText
      value: "\uC21C\uACBD: \uADF8\uB7AC\uB354\uB2C8 \uC5B4\uB5BB\uAC8C \uB410\uB294\uC9C0
        \uC54C\uC544? \uC624\uB298 \uAC11\uC790\uAE30 \uBCF8\uBD80\uC5D0\uC11C \uC0AC\uB78C\uC774
        \uB4E4\uC5B4\uC624\uB354\uB2C8, \uB0B4 \uBAB8\uC744 \uC218\uC0C9\uD558\uACE0
        \uB0A0 \uB0B4\uCAD3\uC558\uC5B4!"
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[6].dialogueText
      value: "\uC21C\uACBD: \uB2E4\uD589\uD788 \uAC00\uC9C0\uACE0 \uC788\uC9C0\uB294
        \uC54A\uC544\uC11C \uC5B4\uB5BB\uAC8C \uB118\uC5B4\uAC14\uC9C0\uB9CC, \uC774\uC81C
        \uB0B4 \uC790\uB9AC\uB97C \uC218\uC0C9\uD558\uACE0 \uC788\uC5B4.\r\n\uADF8\uAC78
        \uCC3E\uC73C\uBA74 \uB09C \uB05D\uC774\uC57C! \uC8FD\uC744 \uAC70\uB77C\uACE0!"
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[7].dialogueText
      value: 
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[8].dialogueText
      value: "\uC21C\uACBD: \uD558, \uB9D0\uC744 \uBABB \uC54C\uC544\uB4E3\uB098
        \uBCF8\uB370, \uB098\uB294 \uC9C0\uAE08 \uB2F9\uC7A5 \uC18C\uB9AC\uCCD0\uC11C
        \uB108\uC758 \uC815\uCCB4\uB97C \uB2E4 \uAE4C\uBC1C\uB9B4\uC218\uB3C4 \uC788\uC5B4,
        \uADF8\uB7FC \uC791\uC804\uC774\uACE0 \uBB50\uACE0 \uB0A0\uC544\uAC00\uB294\uAC70\uC57C.
        \uC798 \uC0DD\uAC01\uD558\uB77C\uACE0."
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[9].dialogueText
      value: "\uC21C\uACBD: \uC800\uAE30 \uC606\uC5D0 \uC788\uB294 \uBC29\uC73C\uB85C
        \uB4E4\uC5B4\uAC00\uC11C, \uB0B4 \uC790\uB9AC\uB97C \uC218\uC0C9\uD558\uACE0
        \uC788\uB294 \uB188\uC744 \uB9C9\uC544\uC918. \uB188\uC774 \uC870\uC6A9\uD558\uAC8C
        \uD574 \uB2EC\uB77C\uACE0. \uAC00\uB2A5\uD558\uBA74 \uD3C9\uC0DD."
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[10].dialogueText
      value: "\uC21C\uACBD"
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[11].dialogueText
      value: "\uC21C\uACBD: \uD558, \uB2E4\uD589\uD788 \uB9D0\uC774 \uC880 \uD1B5\uD558\uB124.
        \uC800\uAE30 \uC606\uC5D0 \uC788\uB294 \uBC29\uC73C\uB85C \uB4E4\uC5B4\uAC00\uC11C,
        \uB188\uC744 \uC870\uC6A9\uD558\uAC8C \uB9CC\uB4E4\uC5B4\uC918. \uAC00\uB2A5\uD558\uBA74
        \uD3C9\uC0DD"
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[7].choices.Array.size
      value: 3
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[8].choices.Array.size
      value: 0
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[7].choices.Array.data[0].choiceText
      value: "\uADF8\uAC8C \uB098\uB791 \uBB34\uC2A8 \uC0C1\uAD00\uC774\uC9C0?"
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[7].choices.Array.data[1].choiceText
      value: "\uC790\uC5C5\uC790\uB4DD\uC774\uAD70."
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[7].choices.Array.data[2].choiceText
      value: "\uB0B4\uAC00 \uCC98\uB9AC\uD574 \uC8FC\uC9C0."
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[8].choices.Array.data[0].choiceText
      value: "\uC81C\uAC00 \uC65C \uADF8\uB798\uC57C \uD558\uC8E0?"
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[8].choices.Array.data[1].choiceText
      value: "\uB9E1\uACA8\uB9CC \uC8FC\uC2DC\uC8E0."
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[8].choices.Array.data[2].choiceText
      value: "\uC2EB\uC740\uB370\uC694."
      objectReference: {fileID: 0}
    - target: {fileID: 885690515818033075, guid: 00d0172b5eabb9347ae3661774491034, type: 3}
      propertyPath: dialogues.Array.data[7].choices.Array.data[0].nextDialogueIndex
